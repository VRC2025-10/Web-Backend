  "query": "\n        SELECT c.id, c.name, c.description_html, c.cover_image_url,\n               u.discord_id as owner_discord_id,\n               u.discord_display_name as owner_display_name,\n               c.created_at\n        FROM clubs c\n        JOIN users u ON u.id = c.owner_user_id\n        WHERE c.id = $1\n        ",
