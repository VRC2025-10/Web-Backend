  "query": "\n        SELECT u.discord_id, u.discord_display_name, cm.role, cm.joined_at\n        FROM club_members cm\n        JOIN users u ON u.id = cm.user_id\n        WHERE cm.club_id = $1\n        ORDER BY cm.joined_at\n        ",
