# ===========================================
# VRC Class Reunion Backend — Environment
# ===========================================
# Copy to .env and fill in real values

# Server
BIND_ADDRESS=0.0.0.0:3000
BACKEND_BASE_URL=https://vrcapi.arivell-vm.com

# PostgreSQL
# Development example:
#   postgres://vrc_app:vrc_dev_password@localhost:5432/vrc_class_reunion
# Production docker-compose example:
#   postgres://vrc_app:<url-encoded-password>@db:5432/vrc_class_reunion
DATABASE_URL=postgres://vrc_app:vrc_dev_password@localhost:5432/vrc_class_reunion
POSTGRES_USER=vrc_app
POSTGRES_PASSWORD=vrc_dev_password
POSTGRES_DB=vrc_class_reunion
POSTGRES_PORT=5432

# Discord OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://vrcapi.arivell-vm.com/api/v1/auth/discord/callback
DISCORD_GUILD_ID=

# Session
SESSION_SECRET=change-me-to-a-random-64-char-hex-string-in-production
SESSION_MAX_AGE_SECS=604800
COOKIE_SECURE=true

# System API
SYSTEM_API_TOKEN=change-me-system-token

# Frontend
FRONTEND_ORIGIN=https://vrc10.arivell-vm.com
# Required when frontend and API live on sibling subdomains and must share session cookies.
# Example: COOKIE_DOMAIN=arivell-vm.com
COOKIE_DOMAIN=

# Gallery uploads
GALLERY_STORAGE_DIR=/var/lib/vrc/gallery
GALLERY_MAX_UPLOAD_BYTES=10485760

# Super Admin bootstrap
# Accepts a single Discord ID or a comma-separated list
SUPER_ADMIN_DISCORD_ID=
