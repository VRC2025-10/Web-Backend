# ===========================================
# VRC Class Reunion Backend — Environment
# ===========================================
# Copy to .env and fill in real values

# Server
BIND_ADDRESS=0.0.0.0:8080

# PostgreSQL
DATABASE_URL=postgres://vrc:vrc_dev_password@localhost:5432/vrc_backend
POSTGRES_USER=vrc
POSTGRES_PASSWORD=vrc_dev_password
POSTGRES_DB=vrc_backend
POSTGRES_PORT=5432

# Discord OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:8080/api/v1/auth/discord/callback
DISCORD_GUILD_ID=

# Session
SESSION_SECRET=change-me-to-a-random-64-char-hex-string-in-production
SESSION_MAX_AGE_SECS=604800
COOKIE_SECURE=false

# System API
SYSTEM_API_TOKEN=change-me-system-token

# Frontend
FRONTEND_ORIGIN=http://localhost:3000

# Super Admin bootstrap
# Accepts a single Discord ID or a comma-separated list
SUPER_ADMIN_DISCORD_ID=
