# =============================================================================
#  .gitignore — VRC Web-Backend
# =============================================================================

# ── Rust / Cargo ─────────────────────────────────────────────────────────────
/target/
**/*.rs.bk

# ── Environment & Secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example
secrets/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log

# ── IDE / Editor ─────────────────────────────────────────────────────────────
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
*.swo
*~

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Docker ───────────────────────────────────────────────────────────────────
docker-compose.override.yml
